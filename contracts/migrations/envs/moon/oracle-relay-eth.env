RPC=https://rpc.api.moonbeam.network
CHAIN_ID=1284
WORMHOLE_CORE=0xC8e2b0cD52Cf01b0Ce87d389Daa3d414d4cE29f3

# XcmTransactor params
#
# FEE_ASSET => hdx
DESTINATION_PARA_ID=2034
SOURCE_PARA_ID=2004
EVM_PALLET_INDEX=90
EVM_CALL_INDEX=1
FEE_ASSET=0xFFFfFfff345Dc44DDAE98Df024Eb494321E73FcC

# Emitter registration (Ethereum)
#
# EMITTER_SOURCE_CHAIN => Wormhole chain id, Ethereum = 2
# EMITTER_ENV          => env under which `oracle-emitter` was deployed
EMITTER_SOURCE_CHAIN=2
EMITTER_ENV=eth

# Oracles registration
#
# ASSET_ID    => keccak256(symbol) — must match what OracleEmitter publishes
# ORACLE_ADDRESS => oracle contract on Hydration EVM (fill in once deployed)

## wstETH
WSTETH_ASSET_ID=0x3725f7650a1fc235623c67881a5755db6c97d7575eddd7351396f0b26fe79334
WSTETH_ORACLE_ADDRESS=0x0000000000000000000000000000000000000000

## apyUSD
APYUSD_ASSET_ID=0xde11c6e5fbb09ebf287fceb58deeb4a0e34ccb69e2deeb25dfe46ad04e35a5a8
APYUSD_ORACLE_ADDRESS=0x0000000000000000000000000000000000000000

{
  "name": "@whm/broadcaster",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "node dist/index.js",
    "prebuild": "npm run clean",
    "build": "node ./esbuild.dist.mjs",
    "clean": "rm -rf dist/",
    "copy:db": "cp db.json dist/",
    "dev": "npm run dev:build & npm run dev:run",
    "dev:build": "node ./esbuild.dev.mjs && npm run copy:db",
    "dev:run": "node --watch --env-file=.env dist/index.js",
    "sync-idl": "npm run sync-idl-json && npm run sync-idl-types",
    "sync-idl-json": "cp ../../platforms/solana/target/idl/message_emitter.json src/emitter/idl.json",
    "sync-idl-types": "cp ../../platforms/solana/target/types/message_emitter.ts src/emitter/types.ts",
    "docker:build": "docker build -t galacticcouncil/broadcaster .",
    "docker:build:amd64": "docker buildx build --platform linux/amd64 -t galacticcouncil/broadcaster:latest --load .",
    "docker:push:amd64": "docker buildx build --platform linux/amd64 -t galacticcouncil/broadcaster:latest --push .",
    "docker:deploy": "docker stack deploy -c docker-compose.yml whm"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.32.1",
    "winston": "^3.8.2",
    "humanize-duration-ts": "~2.1.1"
  }
}

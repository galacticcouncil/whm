{
  "name": "@whm/scan",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node dist/index.js",
    "prebuild": "npm run clean",
    "build": "node ./esbuild.dist.mjs",
    "clean": "rm -rf dist/",
    "dev": "node ./esbuild.dev.mjs",
    "dev:db": "docker compose -f docker-compose.dev.yml up -d",
    "docker:build": "docker build -t galacticcouncil/whmscan:latest .",
    "docker:deploy": "docker buildx build --platform linux/amd64 -t galacticcouncil/whmscan:latest --push .",
    "docker:up": "docker stack deploy -c docker-compose.yml scan"
  },
  "dependencies": {
    "@defuse-protocol/one-click-sdk-typescript": "^0.1.17",
    "@fastify/cors": "^10.0.2",
    "@galacticcouncil/common": "^1.0.0",
    "@galacticcouncil/descriptors": "^2.4.0",
    "@galacticcouncil/sdk-next": "^1.3.0",
    "@noble/hashes": "^1.3.0",
    "fastify": "^5.2.0",
    "pg": "^8.13.1",
    "polkadot-api": "^2.1.0",
    "viem": "^2.38.3",
    "winston": "^3.8.2"
  },
  "devDependencies": {
    "@types/pg": "^8.11.10"
  }
}

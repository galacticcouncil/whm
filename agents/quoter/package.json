{
  "name": "@whm/quoter",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node dist/index.js",
    "prebuild": "npm run clean",
    "build": "node ./esbuild.dist.mjs",
    "clean": "rm -rf dist/",
    "dev": "node ./esbuild.dev.mjs",
    "docker:build": "docker build -t galacticcouncil/quoter:latest .",
    "docker:deploy": "docker buildx build --platform linux/amd64 -t galacticcouncil/quoter:latest --push .",
    "docker:up": "docker stack deploy -c docker-compose.yml quoter"
  },
  "dependencies": {
    "@galacticcouncil/sdk-next": "^1.3.0",
    "@galacticcouncil/xc-cfg": "^1.4.2",
    "fastify": "^5.2.0",
    "polkadot-api": "^2.1.0",
    "viem": "^2.38.3",
    "winston": "^3.8.2"
  }
}

{
  "name": "@whm/bjscan",
  "private": true,
  "scripts": {
    "start": "node dist/index.js",
    "prebuild": "npm run clean",
    "build": "node ./esbuild.dist.mjs",
    "clean": "rm -rf dist/",
    "dev": "node ./esbuild.dev.mjs",
    "dev:db": "docker compose -f docker-compose.dev.yml up -d",
    "docker:build": "docker build -t galacticcouncil/bjscan:latest .",
    "docker:deploy": "docker buildx build --platform linux/amd64,linux/arm64 -t galacticcouncil/bjscan:latest --push .",
    "docker:up": "docker stack deploy -c docker-compose.yml whm"
  },
  "dependencies": {
    "@galacticcouncil/descriptors": "^1.16.0",
    "@galacticcouncil/common": "^0.7.0",
    "fastify": "^5.2.0",
    "pg": "^8.13.1",
    "polkadot-api": "^1.23.3",
    "viem": "^2.38.3",
    "winston": "^3.8.2"
  },
  "devDependencies": {
    "@types/pg": "^8.11.10"
  }
}

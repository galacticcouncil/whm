# === Existing Hydration landing (basejump-base, reused) ===
# Proxy + Basejump are wired to point here; the landing itself is owned by the Hydration TC.
HYDRATION_LANDING=0x70e9b12c3b19cb5f0e59984a5866278ab69df976

# === USDC fee (set on Basejump, source side) ===
# 6 decimals — placeholder, pending team decision (ETH gas >> Base)
USDC_FEE_ASSET=0xA0b86991c6218b36c1d19D4a2e9Eb0cE3606eB48
USDC_FEE_AMOUNT=100000

# === Governance handoff (Hydration TC, NOT executed by this migration) ===
# On the reused landing: setDestAsset(USDC_SOURCE_ASSET → USDC_DEST_ASSET) and
# setAuthorizedBridge(<new XcmTransactor MDA>) are onlyOwner — apply via TC governance after deploy.
USDC_SOURCE_ASSET=0xA0b86991c6218b36c1d19D4a2e9Eb0cE3606eB48        # USDC on Ethereum, 6dp
USDC_DEST_ASSET=0x0000000000000000000000000000000100000015         # USDC.mwh, Hydration currency 21

# === Ownership renunciation targets ===
# MDA of Hydration EmergencyAdminAccount on Moonbeam
PROXY_NEW_OWNER=0xb041705871c4c5537a1a57edd4d62f66217522a7
# Ethereum custodian — TBD: Base TC Safe 0xD557AeAf1e0cB3D226BfF3B7a10C2cdA9dA081E7 has no code

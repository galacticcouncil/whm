{
  "name": "@nohaapav/whm-solana",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "anchor build -p sender",
    "build:local": "anchor build -p sender -- --features local-logs",
    "logs:local": "solana logs -u http://127.0.0.1:8898",
    "validator:cleanup": "rm -rf .anchor/test-ledger",
    "sender:deploy": "npx tsx scripts/sender/deploy.ts",
    "sender:close": "npx tsx scripts/sender/close.ts",
    "sender:runValidator": "npx tsx scripts/sender/runValidator.ts",
    "sender:sendMessage": "npx tsx scripts/sender/sendMessage.ts",
    "sender:sendPrice": "npx tsx scripts/sender/sendPrice.ts",
    "account:getSecret": "npx tsx scripts/getSecret.ts"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/chai": "^5.2.3",
    "chai": "^4.3.4",
    "mocha": "^10.0.0",
    "ts-mocha": "^10.0.0"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.32.1",
    "@nohaapav/whm-sdk": "workspace:*",
    "bip39": "^3.1.0",
    "ed25519-hd-key": "^1.3.0"
  }
}

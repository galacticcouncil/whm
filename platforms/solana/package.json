{
  "name": "@whm/platform-solana",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "anchor build -p message-emitter",
    "test": "cargo test -p message-emitter",
    "build:local": "anchor build -p message-emitter -- --features local-logs",
    "logs:local": "solana logs -u http://127.0.0.1:8898",
    "validator:cleanup": "rm -rf .anchor/test-ledger",
    "emitter:deploy": "npx tsx scripts/emitter/deploy.ts",
    "emitter:close": "npx tsx scripts/emitter/close.ts",
    "emitter:runValidator": "npx tsx scripts/emitter/runValidator.ts",
    "emitter:sendMessage": "npx tsx scripts/emitter/sendMessage.ts",
    "emitter:sendPrice": "npx tsx scripts/emitter/sendPrice.ts",
    "account:getSecret": "npx tsx scripts/getSecret.ts",
    "asset:getBytes32": "npx tsx scripts/getBytes32.ts"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/chai": "^5.2.3",
    "chai": "^4.3.4",
    "mocha": "^10.0.0",
    "ts-mocha": "^10.0.0"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.32.1",
    "@whm/common": "workspace:*",
    "bip39": "^3.1.0",
    "ed25519-hd-key": "^1.3.0"
  }
}

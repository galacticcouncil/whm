{
  "name": "@whm/platform-evm",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "cd contracts && forge build",
    "test": "cd contracts && forge test",
    "migration:run": "npx tsx migrations/run.ts",
    "fork:base": "bash sh/fork-base.sh",
    "fork:moonbeam": "bash sh/fork-moonbeam.sh",
    "fork:hydration": "bash sh/fork-hydration.sh",
    "fork:all": "run-p fork:base fork:moonbeam fork:hydration",
    "migrate:oracle-relay": "bash sh/migrate-oracle-relay.sh",
    "migrate:basejump": "bash sh/migrate-basejump.sh",
    "migrate:basejump:fork": "bash sh/migrate-basejump.sh fork"
  },
  "dependencies": {
    "@galacticcouncil/common": "^0.5.0",
    "@polkadot/api": "^16.5.6",
    "@whm/common": "workspace:*",
    "viem": "^2.38.3"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}
